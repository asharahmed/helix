# Helix - Environment Variables
# Copy to .env.local and fill in the values for your deployment.

# ─── Webhook Authentication ──────────────────────────────────────────
# Pre-shared secret for Alertmanager and Wazuh webhook endpoints.
# Both webhook senders must include this as: Authorization: Bearer <secret>
WEBHOOK_SECRET=

# ─── Prometheus ──────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# ─── Alertmanager ────────────────────────────────────────────────────
ALERTMANAGER_URL=http://alertmanager:9093

# ─── Loki ────────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ─── CrowdSec ───────────────────────────────────────────────────────
CROWDSEC_URL=http://crowdsec:8080
CROWDSEC_BOUNCER_API_KEY=

# ─── Wazuh Manager API ──────────────────────────────────────────────
WAZUH_API_URL=https://wazuh.manager:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=

# ─── Wazuh Indexer (OpenSearch) ──────────────────────────────────────
WAZUH_INDEXER_URL=https://wazuh.indexer:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=

# ─── TLS ─────────────────────────────────────────────────────────────
# Path to the CA certificate for Wazuh services (self-signed certs).
# If not set, falls back to rejectUnauthorized: false (scoped to Wazuh only).
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/wazuh-ca.pem
